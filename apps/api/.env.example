# ─────────────────────────────────────────
# Base de datos — Supabase PostgreSQL
# ─────────────────────────────────────────
# Connection pooling (puerto 6543) — usar en Prisma "url"
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa (puerto 5432) — usar en Prisma "directUrl" para migraciones
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # service_role — NUNCA exponer en cliente

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-secreto-de-al-menos-32-caracteres"
JWT_EXPIRES_IN="7d"

# ─────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_BASIC="price_..."    # ID del precio mensual Básico (5,99€)
STRIPE_PRICE_PRO="price_..."      # ID del precio mensual Pro (14,99€)

# ─────────────────────────────────────────
# Expo Push Notifications
# ─────────────────────────────────────────
# Obtener en: https://expo.dev/accounts/[user]/settings/access-tokens
EXPO_ACCESS_TOKEN="expo_..."

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
