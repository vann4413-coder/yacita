{
  "name": "yacita",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @yacita/api dev",
    "dev:web": "pnpm --filter @yacita/web dev",
    "dev:mobile": "pnpm --filter @yacita/mobile start",
    "build:api": "pnpm --filter @yacita/api build",
    "build:web": "pnpm --filter @yacita/web build",
    "build": "pnpm --filter './packages/**' build && pnpm --filter './apps/**' build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "db:generate": "pnpm --filter @yacita/api db:generate",
    "db:migrate": "pnpm --filter @yacita/api db:migrate",
    "db:studio": "pnpm --filter @yacita/api db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.1",
      "@types/react-dom": "^18.3.0"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
